void __lfortran_c_backend_real_pow_cache_01__calc(double r0, double r1, double alp, double *fdmp, double *dfdmp);




// Implementations
void __lfortran_c_backend_real_pow_cache_01__calc(double r0, double r1, double alp, double *fdmp, double *dfdmp)
{
    double __lfortran_pow_cache = pow(r0/r1, alp/  3.00000000000000000e+00);
    (*fdmp) =   1.00000000000000000e+00/(  1.00000000000000000e+00 +   6.00000000000000000e+00*__lfortran_pow_cache);
    (*dfdmp) = (-  2.00000000000000000e+00)*alp*__lfortran_pow_cache*(((*fdmp))*((*fdmp)));
}

int main(int argc, char* argv[])
{
    _lpython_set_argv(argc, argv);
    double dfdmp;
    double fdmp;
    __lfortran_c_backend_real_pow_cache_01__calc(  2.00000000000000000e+00,   3.00000000000000000e+00,   4.00000000000000000e+00, &fdmp, &dfdmp);
    if (fabs(dfdmp) <   9.99999999999999980e-13) {
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    return 0;
}
