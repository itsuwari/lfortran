    first = 1;
    last = 6;
    if (str_compare((line + (((first) - 1))), ((last) - (((first) - 1))), (char*)"$coord", 6)  ==  0) {
    }
    else {
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    _lfortran_strcpy_alloc(_lfortran_get_default_allocator(), &line, NULL, true, true, (char*)"$end trailing", strlen((char*)"$end trailing"));
    first = 1;
    last = 4;
    if (str_compare((line + (((first) - 1))), ((last) - (((first) - 1))), (char*)"$coord", 6)  ==  0) {
