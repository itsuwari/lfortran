double __lfortran__lcompilers_erf_f64(double x)
{
    double _lcompilers_erf_f64;
    _lcompilers_erf_f64 = _lfortran_derf(x);
    return _lcompilers_erf_f64;
}

void __lfortran_c_backend_real_pow_cache_intrinsic_01(double rc, double norm_exp, double kcn, double r, double *count)
{
    (*count) =   5.00000000000000000e-01*(  1.00000000000000000e+00 + __lfortran__lcompilers_erf_f64((-kcn)*(r - rc)/pow(rc, norm_exp)));
}

