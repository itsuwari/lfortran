int32_t __lfortran_lfortran_intrinsic_custom__get_valid_newunit()
{
    int32_t lun;
    const int32_t lun_max = 1000;
    const int32_t lun_min = 0;
    bool opened;
    int32_t unit;
    for (lun=lun_min; lun<=lun_max; lun++) {
        _lfortran_inquire(NULL, 0, NULL, lun, &(opened), NULL, NULL, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, NULL, NULL, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, NULL, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, NULL, 0, NULL, 0, NULL, 0, NULL, 0);
        if (!opened) {
            unit = lun;
            return unit;
        }
    }
    printf("%s\n",(char*)"All unit numbers are utilized");
    fprintf(stderr, "ERROR STOP");
    exit(1);
    return unit;
}

void __lfortran_lfortran_intrinsic_custom__newunit_int_1(int8_t *unit)
{
    if (__lfortran_lfortran_intrinsic_custom__get_valid_newunit() >= pow(2, 8)) {
        printf("%s\n",(char*)"integer(KIND=1) is has small limit. Use larger kind for the unit number");
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    (*unit) = __lfortran__lcompilers_int_i32(__lfortran_lfortran_intrinsic_custom__get_valid_newunit());
}

