int main(int argc, char* argv[])
{
    _lpython_set_argv(argc, argv);
    char * lfortran_iomsg = NULL;
    char * line = NULL;
    int32_t size;
    int32_t stat;
    int32_t unit;
    __lfortran_lfortran_intrinsic_custom__newunit_int_4(&unit);
    _lfortran_open(unit, NULL, 0, (char*)"scratch", strlen((char*)"scratch"), (char*)"formatted", strlen((char*)"formatted"), NULL, 0, NULL, 0, NULL, (char*)"readwrite", strlen((char*)"readwrite"), NULL, 0, NULL, 0, NULL, 0, NULL, 0, NULL, NULL, 0, NULL, 0, NULL, 0, NULL, 0);
    int __lfortran_write_size_0 = snprintf(NULL, 0, "%s", (char*)"abc");
    char *__lfortran_write_buffer_0 = (char*) malloc((size_t)__lfortran_write_size_0 + 1);
    snprintf(__lfortran_write_buffer_0, (size_t)__lfortran_write_size_0 + 1, "%s", (char*)"abc");
    _lfortran_file_write(unit, NULL, "%s%s", 4, __lfortran_write_buffer_0, (int64_t)__lfortran_write_size_0, "\n", 1);
    free(__lfortran_write_buffer_0);
    _lfortran_rewind(unit, NULL, NULL, 0);
    if (line == NULL) line = (char*) _lfortran_string_malloc_alloc(_lfortran_get_default_allocator(), 512);
    _lfortran_formatted_read(unit, &(stat), &(size), (char*)"no", 2, (char*)"(a)", 3, 1, NULL, 0, 0, 0, &(line), (int64_t)(512));
    if (stat != -2 && stat != 0) {
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    if (size != 3) {
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    if (str_compare((line + (((1) - 1))), ((3) - (((1) - 1))), (char*)"abc", 3)  !=  0) {
        fprintf(stderr, "ERROR STOP");
        exit(1);
    }
    _lfortran_close(unit, NULL, 0, NULL);
    return 0;
}
