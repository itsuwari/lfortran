    a->data[(0 + (1 * (3 - 1)))] =   3.00000000000000000e+00;
    y = (x)*(x) + (x)*(x)*(x) + (x +   1.00000000000000000e+00)*(x +   1.00000000000000000e+00);
    z = pow(__lfortran_c_backend_small_integer_pow_01__next_value(), 2);
    w = (a->data[(0 + (1 * (1 - 1)))])*(a->data[(0 + (1 * (1 - 1)))]) + (a->data[(0 + (1 * (2 - 1)))])*(a->data[(0 + (1 * (2 - 1)))])*(a->data[(0 + (1 * (2 - 1)))]) + (a->data[(0 + (1 * (3 - 1)))])*(a->data[(0 + (1 * (3 - 1)))])*(a->data[(0 + (1 * (3 - 1)))])*(a->data[(0 + (1 * (3 - 1)))]);
    if (fabs(y -   5.20000000000000000e+01) >   9.99999997475242708e-07) {
